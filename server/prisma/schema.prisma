generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  password   String

  // 🔥 Leaderboard Fields
  totalScore Int      @default(0)
  streak     Int      @default(0)

  // 📅 Timestamps
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}